# Production .env — скопируйте на сервер приложения как .env

DATABASE_URL="postgresql://smena:ПАРОЛЬ_БД@IP_СЕРВЕРА_БД:5432/smena_crm?schema=public"
JWT_SECRET=""

NODE_ENV="production"

PLATFORM_DEV_EMAIL="dev@yourdomain.ru"
PLATFORM_DEV_PASSWORD=""

NEXT_PUBLIC_CRM_URL="https://app.yourdomain.ru"
# Публичный URL CRM для ссылок (приглашения). На сервере читается в рантайме — пересборка не обязательна.
CRM_PUBLIC_URL="https://app.yourdomain.ru"
NEXT_PUBLIC_PLATFORM_URL="https://dev.yourdomain.ru"

AITUNNEL_API_KEY=""
AITUNNEL_VISION_MODEL="grok-4.20"
AITUNNEL_ASSISTANT_MODEL="claude-haiku-4.5"
AITUNNEL_HAMSTER_MODEL="claude-sonnet-4.6"
AITUNNEL_EMBEDDING_MODEL="text-embedding-3-small"

S3_ENDPOINT="https://s3.twcstorage.ru"
S3_REGION="ru-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"

MIGRATION_SECRET=""
