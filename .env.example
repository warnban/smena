# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5433/smena_crm?schema=public"

# Required in production — long random string (min 32 chars)
JWT_SECRET="change-me-to-a-long-random-secret"

# Node environment (production enables secure cookies)
NODE_ENV="development"

# Platform developer panel (dev.domen.ru) — separate from CRM users
PLATFORM_DEV_EMAIL="dev@smena.ru"
PLATFORM_DEV_PASSWORD="change-me-platform-dev-password"

# Optional public URLs for landing links (prod)
# NEXT_PUBLIC_CRM_URL="https://app.domen.ru"
# NEXT_PUBLIC_PLATFORM_URL="https://dev.domen.ru"

# AITUNNEL — AI в CRM (сканы документов, помощник, FAQ)
# Ключ: https://aitunnel.ru → Личный кабинет → Ключи
AITUNNEL_API_KEY=""
# Vision — распознавание паспортов / Форма №5
AITUNNEL_VISION_MODEL="grok-4.20"
# Ассистент админов (чат + инструменты)
AITUNNEL_ASSISTANT_MODEL="claude-haiku-4.5"
# Эмбеддинги для поиска по FAQ
AITUNNEL_EMBEDDING_MODEL="text-embedding-3-small"
# Обратная совместимость (fallback для vision, если AITUNNEL_VISION_MODEL не задан)
# AITUNNEL_MODEL="grok-4.20"

# Импорт из старой CRM (bot) — тот же секрет на обоих серверах
MIGRATION_SECRET=""

# S3-хранилище файлов (сканы, документы). Без этих переменных — локально public/uploads/
# Timeweb Cloud:
# S3_ENDPOINT="https://s3.twcstorage.ru"
# S3_REGION="ru-1"
# S3_BUCKET="your-bucket-id"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_FORCE_PATH_STYLE="true"
